<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    MCPHub depends only on public packages from nuget.org.
    We <clear/> inherited (machine/user) sources so restore is deterministic and
    avoids the central-package-management multi-source warning (NU1507).
    Add internal/private feeds here later if MCPHub ever needs them.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
