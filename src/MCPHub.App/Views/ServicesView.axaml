<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MCPHub.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="560"
             x:Class="MCPHub.App.Views.ServicesView"
             x:DataType="vm:ServicesViewModel">

  <DockPanel Margin="24">

    <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,12">
      <TextBlock Text="Managed MCP Servers" FontSize="20" FontWeight="SemiBold"/>
      <TextBlock Text="The Wixely MCPSharp suite — download, run and update from one place."
                 Opacity="0.65"/>
    </StackPanel>

    <!-- Toolbar -->
    <Grid DockPanel.Dock="Top" Margin="0,0,0,12" ColumnDefinitions="Auto,Auto,*">
      <Button Grid.Column="0"
              Content="Check for updates"
              Command="{Binding CheckAllUpdatesCommand}"
              IsEnabled="{Binding !IsChecking}"/>
      <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="120" Height="4"
                   Margin="14,0" VerticalAlignment="Center"
                   IsVisible="{Binding IsChecking}"/>
      <TextBlock Grid.Column="2" Text="{Binding StatusMessage}"
                 VerticalAlignment="Center" Opacity="0.7"
                 TextTrimming="CharacterEllipsis"/>
    </Grid>

    <!-- Column header -->
    <Border DockPanel.Dock="Top" Background="#14000000" CornerRadius="6,6,0,0" Padding="14,9">
      <Grid ColumnDefinitions="*,52,80,104,116,300">
        <TextBlock Grid.Column="0" Text="Service" FontWeight="SemiBold"/>
        <TextBlock Grid.Column="1" Text="Port" FontWeight="SemiBold"/>
        <TextBlock Grid.Column="2" Text="Installed" FontWeight="SemiBold"/>
        <TextBlock Grid.Column="3" Text="Latest" FontWeight="SemiBold"/>
        <TextBlock Grid.Column="4" Text="State" FontWeight="SemiBold"/>
        <TextBlock Grid.Column="5" Text="Actions" FontWeight="SemiBold"/>
      </Grid>
    </Border>

    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Services}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ManagedServiceViewModel">
            <Border BorderBrush="#18000000" BorderThickness="0,0,0,1" Padding="14,8">
              <Grid ColumnDefinitions="*,52,80,104,116,300" VerticalAlignment="Center">

                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                  <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Description}" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="{Binding PortText}" VerticalAlignment="Center" Opacity="0.85"/>
                <TextBlock Grid.Column="2" Text="{Binding InstalledVersion}" VerticalAlignment="Center" Opacity="0.85"/>

                <!-- Latest + update-status dot -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center"
                            ToolTip.Tip="{Binding UpdateStatusText}">
                  <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                          Background="{Binding UpdateStatus, Converter={StaticResource UpdateStatusToBrush}}"/>
                  <TextBlock Text="{Binding LatestVersion}" Opacity="0.85"/>
                </StackPanel>

                <!-- Run state -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                  <Border Width="9" Height="9" CornerRadius="5" VerticalAlignment="Center"
                          Background="{Binding RunState, Converter={StaticResource RunStateToBrush}}"/>
                  <TextBlock Text="{Binding RunStateText}" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Actions -->
                <Panel Grid.Column="5">
                  <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                              IsVisible="{Binding !IsInstalling}">
                    <Button Content="{Binding InstallButtonText}" Padding="8,4" Command="{Binding InstallCommand}"/>
                    <Button Content="Start" Padding="8,4" Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}"/>
                    <Button Content="Stop" Padding="8,4" Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"/>
                    <Button Content="Config" Padding="8,4" Command="{Binding EditConfigCommand}"
                            IsEnabled="{Binding CanEditConfig}" ToolTip.Tip="{Binding ConfigFileName}"/>
                    <Button Content="Logs" Padding="8,4" Command="{Binding ViewLogsCommand}"/>
                  </StackPanel>
                  <ProgressBar IsVisible="{Binding IsInstalling}" Minimum="0" Maximum="1"
                               Value="{Binding InstallProgress}" Height="6" VerticalAlignment="Center"
                               ShowProgressText="True"/>
                </Panel>

              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </DockPanel>
</UserControl>
