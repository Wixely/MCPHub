<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MCPHub.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="560"
             x:Class="MCPHub.App.Views.ServicesView"
             x:DataType="vm:ServicesViewModel">

  <DockPanel Margin="24">

    <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,16">
      <TextBlock Text="Managed MCP Servers" FontSize="20" FontWeight="SemiBold"/>
      <TextBlock Text="The Wixely MCPSharp suite — download, run and update from one place."
                 Opacity="0.65"/>
    </StackPanel>

    <!-- Column header -->
    <Border DockPanel.Dock="Top" Background="#14000000" CornerRadius="6,6,0,0" Padding="14,9">
      <Grid ColumnDefinitions="*,80,110,110,120">
        <TextBlock Grid.Column="0" Text="Service" FontWeight="SemiBold"/>
        <TextBlock Grid.Column="1" Text="Port" FontWeight="SemiBold"/>
        <TextBlock Grid.Column="2" Text="Installed" FontWeight="SemiBold"/>
        <TextBlock Grid.Column="3" Text="Latest" FontWeight="SemiBold"/>
        <TextBlock Grid.Column="4" Text="Status" FontWeight="SemiBold"/>
      </Grid>
    </Border>

    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Services}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ManagedServiceViewModel">
            <Border BorderBrush="#18000000" BorderThickness="0,0,0,1" Padding="14,10">
              <Grid ColumnDefinitions="*,80,110,110,120" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                  <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Description}" Opacity="0.65" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding PortText}" VerticalAlignment="Center" Opacity="0.85"/>
                <TextBlock Grid.Column="2" Text="{Binding InstalledVersion}" VerticalAlignment="Center" Opacity="0.85"/>
                <TextBlock Grid.Column="3" Text="{Binding LatestVersion}" VerticalAlignment="Center" Opacity="0.85"/>
                <Border Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Left"
                        Background="#1F000000" CornerRadius="10" Padding="10,3">
                  <TextBlock Text="{Binding RunState}" FontSize="12"/>
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </DockPanel>
</UserControl>
