<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MCPHub.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="620"
             x:Class="MCPHub.App.Views.SlopworksView"
             x:DataType="vm:SlopworksViewModel">

  <ScrollViewer>
    <StackPanel Margin="24" Spacing="16" MaxWidth="820" HorizontalAlignment="Left">

      <StackPanel Spacing="2">
        <TextBlock Text="{Binding DisplayName}" FontSize="20" FontWeight="SemiBold"/>
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="{Binding Description}" Opacity="0.65" VerticalAlignment="Center"/>
          <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/Wixely/Slopworks"
                           Padding="0" VerticalAlignment="Center"/>
        </StackPanel>
      </StackPanel>

      <!-- Install / version card -->
      <Border Background="#14000000" CornerRadius="8" Padding="16">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="120,120,*,Auto" ColumnSpacing="16">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="Installed" Opacity="0.6" FontSize="12"/>
              <TextBlock Text="{Binding InstalledVersion}" FontWeight="SemiBold"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="Latest" Opacity="0.6" FontSize="12"/>
              <TextBlock Text="{Binding LatestVersion}" FontWeight="SemiBold"/>
            </StackPanel>
            <Button Grid.Column="2" Content="Check for updates" HorizontalAlignment="Left" VerticalAlignment="Center"
                    Command="{Binding CheckUpdatesCommand}" IsEnabled="{Binding !IsBusy}"/>
            <Panel Grid.Column="3" VerticalAlignment="Center">
              <Button Content="{Binding InstallButtonText}" Width="96" HorizontalContentAlignment="Center"
                      Command="{Binding InstallCommand}" IsVisible="{Binding !IsInstalling}"/>
              <ProgressBar IsVisible="{Binding IsInstalling}" Minimum="0" Maximum="1" Width="96"
                           Value="{Binding InstallProgress}" Height="8"/>
            </Panel>
          </Grid>
          <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" FontSize="12" TextWrapping="Wrap"
                     IsVisible="{Binding HasStatus}"/>
        </StackPanel>
      </Border>

      <!-- Status card (populated by `slopworks status` (JSON output) on load + refresh) -->
      <Border Background="#14000000" CornerRadius="8" Padding="16">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="Server status" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshStatusCommand}"
                    IsEnabled="{Binding IsInstalled}"
                    ToolTip.Tip="Re-run 'Slopworks.App.exe status --json' — no auto-polling."/>
          </Grid>
          <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="16">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Container" Opacity="0.6" FontSize="12"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ContainerState}" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="API" Opacity="0.6" FontSize="12"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ApiHealthText}" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Endpoint" Opacity="0.6" FontSize="12"/>
            <SelectableTextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Endpoint}"/>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Model" Opacity="0.6" FontSize="12"/>
            <SelectableTextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Model}"/>
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Port" Opacity="0.6" FontSize="12"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PortText}"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Start / stop -->
      <StackPanel Spacing="10">
        <TextBlock Text="Server" FontWeight="SemiBold"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Start" Command="{Binding StartCommand}" IsEnabled="{Binding IsInstalled}"
                  ToolTip.Tip="Run 'Slopworks.App.exe start' — starts the vLLM container. First pull may take a while."/>
          <Button Content="Stop" Command="{Binding StopCommand}" IsEnabled="{Binding IsInstalled}"
                  ToolTip.Tip="Run 'Slopworks.App.exe stop' — stops the vLLM container."/>
          <Button Content="Open in Explorer" Command="{Binding OpenFolderCommand}"
                  ToolTip.Tip="Open the folder Slopworks is installed in"/>
        </StackPanel>
        <TextBlock Text="Start / Stop shell out to the Slopworks CLI. Output streams into the Logs tab (as &quot;Slopworks&quot;). Slopworks itself keeps its config under %AppData% — MCPHub only manages the binary."
                   Opacity="0.55" FontSize="12" TextWrapping="Wrap"/>
      </StackPanel>

      <!-- DaggerAgent integration -->
      <StackPanel Spacing="10">
        <TextBlock Text="DaggerAgent integration" FontWeight="SemiBold"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Add to Dagger endpoints" Command="{Binding AddDaggerEndpointCommand}"
                  IsEnabled="{Binding DaggerAvailable}"
                  ToolTip.Tip="Add (or refresh) a vLLM entry in DaggerAgent's appsettings.json Endpoints array using the currently-configured Slopworks model + port. Idempotent per model — click again after changing the model in Slopworks to add another endpoint."/>
        </StackPanel>
        <TextBlock Text="Slopworks-managed endpoints are keyed on model, so re-clicking after a model change adds a new entry without touching your existing ones. On install, MCPHub wires this automatically if DaggerAgent is already installed; otherwise it happens the next time DaggerAgent is installed. Disabled when DaggerAgent isn't installed."
                   Opacity="0.55" FontSize="12" TextWrapping="Wrap"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
