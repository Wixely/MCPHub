<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:MCPHub.App"
             xmlns:conv="using:MCPHub.App.Converters"
             x:Class="MCPHub.App.App"
             RequestedThemeVariant="Default">

  <Application.Resources>
    <conv:UpdateStatusToBrushConverter x:Key="UpdateStatusToBrush" />
    <conv:RunStateToBrushConverter x:Key="RunStateToBrush" />
    <conv:LogStreamToBrushConverter x:Key="LogStreamToBrush" />
    <conv:UpstreamStateToBrushConverter x:Key="UpstreamStateToBrush" />
    <conv:RunningToBrushConverter x:Key="RunningToBrush" />
  </Application.Resources>

  <Application.DataTemplates>
    <local:ViewLocator />
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme />
  </Application.Styles>

  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="/Assets/mcphub.ico" ToolTipText="MCPHub" Clicked="OnTrayIconClicked">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Open MCPHub" Click="OnTrayOpen" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Exit" Click="OnTrayExit" />
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>

</Application>
