<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:MCPHub.App"
             xmlns:conv="using:MCPHub.App.Converters"
             x:Class="MCPHub.App.App"
             RequestedThemeVariant="Default">

  <Application.Resources>
    <conv:UpdateStatusToBrushConverter x:Key="UpdateStatusToBrush" />
    <conv:RunStateToBrushConverter x:Key="RunStateToBrush" />
    <conv:LogStreamToBrushConverter x:Key="LogStreamToBrush" />
    <conv:UpstreamStateToBrushConverter x:Key="UpstreamStateToBrush" />
    <conv:RunningToBrushConverter x:Key="RunningToBrush" />
  </Application.Resources>

  <Application.DataTemplates>
    <local:ViewLocator />
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme />

    <!-- Green "launch" button: solid green while enabled, greys out to the card colour when
         disabled (e.g. the product isn't installed). Applied via Classes="launch". -->
    <Style Selector="Button.launch">
      <Setter Property="Background" Value="#2EA043"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.launch:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#3FB950"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.launch:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#238636"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.launch:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#14000000"/>
      <Setter Property="Foreground" Value="#80FFFFFF"/>
    </Style>
  </Application.Styles>

  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="/Assets/mcphub.png" ToolTipText="MCPHub" Clicked="OnTrayIconClicked">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Open MCPHub" Click="OnTrayOpen" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Exit" Click="OnTrayExit" />
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>

</Application>
